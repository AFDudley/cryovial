# Environment configuration for the cryovial container.
#
# These are injected into the container via ConfigMap (envFrom in spec.yml).

# Default k8s namespace for MCP kubectl queries
EXOPHIAL_DEFAULT_NAMESPACE=laconic-gorbagana-rpc

# Backup git remote for coord.git (synced on startup)
# COORD_GIT_BACKUP_URL=git@github.com:AFDudley/exophial-coord.git

# Image watcher config path (inside the container)
# Set to enable automatic deploy-on-new-image behavior.
# EXOPHIAL_WATCH_CONFIG=/home/exophial/watch-config.yaml

# Poll interval for image watcher (seconds)
EXOPHIAL_POLL_INTERVAL=300
